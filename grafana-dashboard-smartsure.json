{
  "id": null,
  "uid": "smartsure-observability",
  "title": "SmartSure Observability",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "tags": ["smartsure", "observability"],
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "API Request Count",
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (application) (increase(http_server_requests_seconds_count[5m]))",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API Latency (P95)",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, application) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate (5xx)",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (application) (increase(http_server_requests_seconds_count{status=~\"5..\"}[5m]))",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM Memory Used",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (application) (jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU Usage",
      "id": 5,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (application) (system_cpu_usage)",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Policies Created",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (increase(policies_created_total[5m]))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Claims Submitted",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (increase(claims_submitted_total[5m]))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Event Throughput (5m)",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (increase(policies_created_total[5m]))",
          "legendFormat": "policies_created ({{service}})"
        },
        {
          "refId": "B",
          "expr": "sum by (service) (increase(claims_submitted_total[5m]))",
          "legendFormat": "claims_submitted ({{service}})"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Duplicate Events (5m)",
      "id": 9,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service, eventType) (increase(events.duplicates[5m]))",
          "legendFormat": "{{service}} {{eventType}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Event Processing Latency (ms)",
      "id": 10,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "1000 * (sum by (service, eventType) (rate(events_processing_seconds_sum[5m])) / sum by (service, eventType) (rate(events_processing_seconds_count[5m])))",
          "legendFormat": "{{service}} {{eventType}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Event Processing Latency P95 (ms)",
      "id": 11,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "1000 * histogram_quantile(0.95, sum by (le, service, eventType) (rate(events_processing_seconds_bucket[5m])))",
          "legendFormat": "{{service}} {{eventType}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Event Processing Latency P99 (ms)",
      "id": 12,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "1000 * histogram_quantile(0.99, sum by (le, service, eventType) (rate(events_processing_seconds_bucket[5m])))",
          "legendFormat": "{{service}} {{eventType}}"
        }
      ]
    }
  ]
}
