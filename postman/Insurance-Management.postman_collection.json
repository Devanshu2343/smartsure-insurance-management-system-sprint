{
  "info": {
    "name": "Insurance Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8080"},
    {"key": "customerToken", "value": ""},
    {"key": "adminToken", "value": ""},
    {"key": "policyId", "value": ""},
    {"key": "claimId", "value": ""},
    {"key": "adminPolicyId", "value": ""}
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Gateway Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/actuator/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Pass@123\",\n  \"role\": \"CUSTOMER\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin@123\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.token) {",
                  "  pm.collectionVariables.set('customerToken', jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Pass@123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.token) {",
                  "  pm.collectionVariables.set('adminToken', jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Policies",
      "item": [
        {
          "name": "Purchase Policy",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.id) {",
                  "  pm.collectionVariables.set('policyId', jsonData.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{customerToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policyType\": \"Health\",\n  \"coverageAmount\": 100000,\n  \"premiumAmount\": 2500,\n  \"startDate\": \"2026-04-01\",\n  \"endDate\": \"2027-03-31\",\n  \"customerEmail\": \"john@example.com\"\n}"
            },
            "url": "{{baseUrl}}/api/policies/purchase"
          }
        },
        {
          "name": "Get Policy By Id",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{customerToken}}"}
            ],
            "url": "{{baseUrl}}/api/policies/{{policyId}}"
          }
        }
      ]
    },
    {
      "name": "Claims",
      "item": [
        {
          "name": "Initiate Claim",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.id) {",
                  "  pm.collectionVariables.set('claimId', jsonData.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{customerToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policyId\": {{policyId}},\n  \"claimAmount\": 1200,\n  \"description\": \"Hospital expense reimbursement\",\n  \"customerEmail\": \"john@example.com\"\n}"
            },
            "url": "{{baseUrl}}/api/claims/initiate"
          }
        },
        {
          "name": "Upload Claim Document",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{customerToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"claimId\": {{claimId}},\n  \"documentUrl\": \"https://files.example.com/claim-doc.pdf\"\n}"
            },
            "url": "{{baseUrl}}/api/claims/upload"
          }
        },
        {
          "name": "Get Claim Status",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{customerToken}}"}
            ],
            "url": "{{baseUrl}}/api/claims/status/{{claimId}}"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Review Claim",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{adminToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"decision\": \"APPROVED\",\n  \"remarks\": \"Approved after document verification\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/claims/{{claimId}}/review"
          }
        },
        {
          "name": "Create Admin Policy",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.id) {",
                  "  pm.collectionVariables.set('adminPolicyId', jsonData.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{adminToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policyCode\": \"HLT-001\",\n  \"policyName\": \"Standard Health Plan\",\n  \"category\": \"Health\",\n  \"baseCoverage\": 50000,\n  \"basePremium\": 1500,\n  \"durationInMonths\": 12,\n  \"active\": true\n}"
            },
            "url": "{{baseUrl}}/api/admin/policies"
          }
        },
        {
          "name": "Get Admin Policy",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"}
            ],
            "url": "{{baseUrl}}/api/admin/policies/{{adminPolicyId}}"
          }
        },
        {
          "name": "List Admin Policies",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"}
            ],
            "url": "{{baseUrl}}/api/admin/policies"
          }
        },
        {
          "name": "Update Admin Policy",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{adminToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policyCode\": \"HLT-001\",\n  \"policyName\": \"Standard Health Plan Plus\",\n  \"category\": \"Health\",\n  \"baseCoverage\": 80000,\n  \"basePremium\": 2200,\n  \"durationInMonths\": 12,\n  \"active\": true\n}"
            },
            "url": "{{baseUrl}}/api/admin/policies/{{adminPolicyId}}"
          }
        },
        {
          "name": "Delete Admin Policy",
          "request": {
            "method": "DELETE",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"}
            ],
            "url": "{{baseUrl}}/api/admin/policies/{{adminPolicyId}}"
          }
        },
        {
          "name": "Report Summary",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"}
            ],
            "url": "{{baseUrl}}/api/reports/summary"
          }
        }
      ]
    }
  ]
}
